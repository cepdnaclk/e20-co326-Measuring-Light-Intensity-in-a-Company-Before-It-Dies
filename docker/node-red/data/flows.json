    {
        "id": "f1a9f6b34fbe4e2d",
        "type": "function",
        "z": "fde217c77fb16fbe",
        "name": "Parse Simulator Payload",
        "func": "let data = msg.payload;\nif (typeof data === \"string\") {\n    try {\n        data = JSON.parse(data);\n    } catch (e) {\n        node.warn(\"Simulator payload is not valid JSON\");\n        return null;\n    }\n}\n\nif (!data || typeof data !== \"object\") {\n    return null;\n}\n\nconst topicParts = String(msg.topic || \"\").split(\"/\");\nconst topicSite = topicParts[1] || \"sitea\";\nconst topicFloor = topicParts[2] || \"floor1\";\nconst topicLine = topicParts[3] || \"line1\";\nconst topicCell = topicParts[4] || \"cell1\";\nconst topicLampId = topicParts[5] || \"unknown_lamp\";\n\nconst lamp = data?.lamp || {};\nconst location = lamp?.location || {};\n\nmsg.payload = {\n    ldr: Number(data?.sensors?.ldrAdc ?? data?.sensors?.ldr ?? 0),\n    ripple_percent: Number(data?.sensors?.ripplePercent ?? 0),\n    rgb_r: Number(data?.sensors?.tcs34725?.R ?? 0),\n    rgb_g: Number(data?.sensors?.tcs34725?.G ?? 0),\n    rgb_b: Number(data?.sensors?.tcs34725?.B ?? 0),\n    rgb_c: Number(data?.sensors?.tcs34725?.C ?? 0),\n    anomaly_score: Number(data?.derived?.anomalyScore ?? 0),\n    rul_hours: Number(data?.derived?.rulHours ?? 0),\n    sim_time_hours: Number(data?.sim?.timeHours ?? 0),\n    sim_speed: Number(data?.sim?.speed ?? 0),\n    sim_playing: Number(data?.sim?.playing ? 1 : 0),\n    ambient_temp: Number(data?.environment?.ambientTemp ?? 0),\n    humidity: Number(data?.environment?.humidity ?? 0),\n    drive_current: Number(data?.environment?.driveCurrent ?? 0),\n    lamp_id: String(lamp?.id ?? topicLampId),\n    site: String(location?.site ?? topicSite),\n    floor: String(location?.floor ?? topicFloor),\n    line: String(location?.line ?? topicLine),\n    cell: String(location?.cell ?? topicCell),\n    source: \"simulated\"\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
